#!/usr/bin/env bash
# SPDX-License-Identifier: MPL-2.0
# Copyright 2026 hyperpolymath
#
# git-garbage-reap — opt-in + provably-merged branch reaper. See SPEC.md.
#
# A branch dies ONLY if (M) it is marked & expired, OR (P) it is provably merged.
# Unmarked + unmerged branches are NEVER touched. Every deletion is backed by a
# git bundle + a restore manifest. Dry-run is the default; --apply deletes.
#
#   git-garbage-reap local  [--apply] [ROOT]   # local branches under ROOT (default: .)
#   git-garbage-reap remote [--apply] [ROOT]   # merged remote branches (hyperpolymath/* only)
#   git-garbage-reap restore <manifest.tsv>    # recreate branches from a manifest
#
# Env: GARBAGE_STATE (backup+manifest dir, default ./.git-garbage-state)
#      OWNER_GLOB    (remote-safety: only act on origins matching this; default 'hyperpolymath')
set -uo pipefail

MODE="${1:-}"; shift || true
APPLY="no"; ROOT="."
for a in "$@"; do
  case "$a" in
    --apply) APPLY="yes";;
    *) ROOT="$a";;
  esac
done
STATE="${GARBAGE_STATE:-$ROOT/.git-garbage-state}"
OWNER_GLOB="${OWNER_GLOB:-hyperpolymath}"
TODAY="$(date -u +%Y-%m-%d)"
export GIT_TERMINAL_PROMPT=0

die(){ echo "git-garbage-reap: $*" >&2; exit 2; }
repos(){ find "$ROOT" -type d -name .git -prune 2>/dev/null | sed 's:/\.git$::' \
         | grep -Ev '/\.lake/|/node_modules/|/vendor/|/_build/|/deps/|/packages/' | sort; }

default_branch(){ local r="$1" d
  for d in main master; do
    if git -C "$r" show-ref --verify --quiet "refs/heads/$d" 2>/dev/null \
       || git -C "$r" show-ref --verify --quiet "refs/remotes/origin/$d" 2>/dev/null; then
      echo "$d"; return; fi
  done
  git -C "$r" symbolic-ref --short -q HEAD 2>/dev/null; }

# keep-list match against .git-garbage.toml at repo root
keep_match(){ local r="$1" br="$2" f="$1/.git-garbage.toml" pat
  [ -f "$f" ] || return 1
  while read -r pat; do [ -z "$pat" ] && continue; case "$br" in $pat) return 0;; esac; done \
    < <(sed -n 's/.*keep[[:space:]]*=[[:space:]]*\[\(.*\)\].*/\1/p' "$f" | tr ',' '\n' | tr -d '"' | sed 's/[[:space:]]//g')
  return 1; }

# Does the branch name carry an EXPIRED marker?  echoes "yes <reason>" or nothing
marked_expired(){ local br="$1" d
  case "$br" in garbage/*) echo "yes garbage/(throwaway)"; return;; esac
  if [[ "$br" =~ ^ttl/([0-9]{4}-[0-9]{2}-[0-9]{2})/ ]]; then d="${BASH_REMATCH[1]}"
    [[ "$d" < "$TODAY" || "$d" == "$TODAY" ]] && echo "yes ttl-expired($d)"; return; fi
  if [[ "$br" =~ --expires-([0-9]{4}-[0-9]{2}-[0-9]{2})(/|$) ]]; then d="${BASH_REMATCH[1]}"
    [[ "$d" < "$TODAY" || "$d" == "$TODAY" ]] && echo "yes suffix-expired($d)"; return; fi
}

mkstate(){ mkdir -p "$STATE/backups"; }

reap_local(){
  mkstate; local man="$STATE/reaped-local-$(date -u +%Y%m%dT%H%M%S).tsv"; : > "$man"
  local n=0
  while read -r r; do
    local def cur; def="$(default_branch "$r")"; [ -z "$def" ] && continue
    cur="$(git -C "$r" symbolic-ref --short -q HEAD 2>/dev/null)"
    while read -r br; do
      [ -z "$br" ] && continue
      [ "$br" = "$def" ] && continue
      [ "$br" = "$cur" ] && continue
      keep_match "$r" "$br" && continue
      local me reason="" merged=no
      me="$(marked_expired "$br")"
      if git -C "$r" merge-base --is-ancestor "$br" "$def" 2>/dev/null; then merged=yes; fi
      local up; up="$(git -C "$r" for-each-ref --format='%(upstream:track,nobracket)' "refs/heads/$br" 2>/dev/null)"
      if [ -n "$me" ]; then reason="${me#yes }"
      elif [ "$merged" = yes ]; then reason="merged-into-$def"
      elif [ "$up" = "gone" ]; then reason="upstream-gone"
      else continue; fi   # unmarked + unmerged => NEVER
      local sha; sha="$(git -C "$r" rev-parse "$br" 2>/dev/null)"
      echo -e "${r#$ROOT/}\t$br\t$sha\t$reason" >> "$man"; n=$((n+1))
      if [ "$APPLY" = yes ]; then
        git -C "$r" bundle create "$STATE/backups/${r//\//__}__${br//\//__}.bundle" "$br" >/dev/null 2>&1
        git -C "$r" branch -D "$br" >/dev/null 2>&1 && echo "reaped  ${r#$ROOT/} : $br  [$reason]" \
          || echo "FAILED  ${r#$ROOT/} : $br"
      else
        echo "would-reap  ${r#$ROOT/} : $br  [$reason]"
      fi
    done < <(git -C "$r" for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null)
  done < <(repos)
  local label="DRY-RUN"; [ "$APPLY" = yes ] && label="REAPED"
  echo; echo "$label: $n branch(es). manifest: $man"
}

reap_remote(){
  mkstate; local man="$STATE/reaped-remote-$(date -u +%Y%m%dT%H%M%S).tsv"; : > "$man"
  local n=0
  while read -r r; do
    local url; url="$(git -C "$r" remote get-url origin 2>/dev/null)" || continue
    echo "$url" | grep -qiE "$OWNER_GLOB" || continue          # never touch third-party/forks
    local def; def="$(default_branch "$r")"; [ -z "$def" ] && continue
    git -C "$r" show-ref --verify --quiet "refs/remotes/origin/$def" || continue
    local nwo; nwo="$(echo "$url" | sed -E 's#.*github.com[:/]##; s#\.git$##')"
    while read -r rb; do
      local br="${rb#origin/}"
      [ "$br" = HEAD ] && continue; [ "$br" = "$def" ] && continue; [ -z "$br" ] && continue
      keep_match "$r" "$br" && continue
      local me reason=""
      me="$(marked_expired "$br")"
      if [ -n "$me" ]; then reason="${me#yes }"
      elif git -C "$r" merge-base --is-ancestor "$rb" "origin/$def" 2>/dev/null; then reason="merged-into-$def"
      else continue; fi
      # never delete a branch that backs an OPEN PR
      if command -v gh >/dev/null 2>&1; then
        gh pr list -R "$nwo" --head "$br" --state open --json number -q '.[].number' 2>/dev/null | grep -q . \
          && { echo "skip(open PR)  $nwo : $br"; continue; }
      fi
      local sha; sha="$(git -C "$r" rev-parse "$rb" 2>/dev/null)"
      echo -e "$nwo\t$br\t$sha\tgit -C $r push origin $sha:refs/heads/$br" >> "$man"; n=$((n+1))
      if [ "$APPLY" = yes ]; then
        git -C "$r" push origin --delete "$br" >/dev/null 2>&1 && echo "reaped  $nwo : $br  [$reason]" \
          || echo "FAIL/gone  $nwo : $br"
      else
        echo "would-reap  $nwo : $br  [$reason]"
      fi
    done < <(git -C "$r" for-each-ref --format='%(refname:short)' refs/remotes/origin 2>/dev/null)
  done < <(repos)
  local label="DRY-RUN"; [ "$APPLY" = yes ] && label="REAPED"
  echo; echo "$label: $n remote branch(es). manifest: $man"
}

restore(){ local m="${1:-}"; [ -f "$m" ] || die "manifest not found: $m"
  # Local repo paths resolve against REPO_ROOT (default: CWD). Remote rows carry an absolute git -C cmd.
  local base="${REPO_ROOT:-.}"
  while IFS=$'\t' read -r a b c d; do
    case "$d" in git\ *) eval "$d" && echo "restored remote $a : $b" || echo "skip $a : $b";;
      *) git -C "$base/$a" branch "$b" "$c" 2>/dev/null && echo "restored $a : $b" || echo "exists/skip $a : $b";;
    esac
  done < "$m"; }

case "$MODE" in
  local)   reap_local;;
  remote)  reap_remote;;
  restore) restore "$ROOT";;   # in restore mode the positional arg (ROOT) is the manifest path
  *) die "usage: git-garbage-reap {local|remote} [--apply] [ROOT] | restore <manifest.tsv>";;
esac
